# =============================================================================
# OneChain Ninja — Environment Variables
# =============================================================================

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=

# --- JWT (session tokens, HS256) ---
JWT_SECRET=
JWT_REFRESH_SECRET=

# --- zkLogin (Sui zero-knowledge login for Telegram users) ---
# PEM-encoded RSA-2048 private key (replace literal \n with newlines).
# Generate with: openssl genrsa 2048
ZKLOGIN_RSA_PRIVATE_KEY=

# The issuer URL embedded in zkLogin JWTs. Must match the publicly reachable
# domain that serves GET /api/auth/.well-known/jwks.json
ZKLOGIN_JWT_ISSUER=https://ninja-api.onechainops.com

# Audience claim for zkLogin JWTs
ZKLOGIN_JWT_AUDIENCE=onechain-ninja

# 32-byte hex master key used for deterministic salt derivation (HMAC-SHA256).
# Generate with: openssl rand -hex 32
ZKLOGIN_SALT_MASTER_KEY=

# ZK Prover endpoint (OneLabs)
ZKLOGIN_PROVER_URL=https://prover-testnet.onelabs.cc/v1

# --- Frontend (REACT_APP_ prefix required for Create React App) ---
REACT_APP_API_BASE_URL=http://localhost:3001
REACT_APP_ONECHAIN_RPC=https://rpc-mainnet.onelabs.cc:443
REACT_APP_ONECHAIN_NETWORK=mainnet
REACT_APP_ZKLOGIN_ENABLED=true
REACT_APP_ZKLOGIN_PROVER_URL=https://prover-testnet.onelabs.cc/v1

# --- Database ---
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- OneChain Contracts ---
# PACKAGE_ID=0x...
# GAME_LOBBY_ID=0x...
# STATS_REGISTRY_ID=0x...
