# OneChain Backend Configuration

# Server
NODE_ENV=development
PORT=3001

# Frontend URLs (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:3000,https://yourdomain.com

# OneChain Configuration
ONECHAIN_RPC=https://rpc-testnet.onelabs.cc:443
ONECHAIN_NETWORK=testnet
ONECHAIN_API=https://api.onelabs.cc

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Security
JWT_SECRET=your_jwt_secret_key_here_change_in_production
SESSION_SECRET=your_session_secret_key_here_change_in_production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Game Configuration
GAME_TIMEOUT_MS=300000
MAX_ACTIVE_GAMES_PER_PLAYER=3
MIN_BET_AMOUNT=100000000
MAX_BET_AMOUNT=10000000000

# Logging
LOG_LEVEL=info
