# Server
PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# OneChain Backend Configuration
ONECHAIN_API_ENDPOINT=https://api.onelabs.cc
ONECHAIN_NETWORK=testnet
ONECHAIN_PROJECT_ID=your_project_id_here
ONECHAIN_API_KEY=your_api_key_here
GAME_CONTRACT_ADDRESS=your_contract_address_here

# OneChain Features
ONEID_ENABLED=false
ONEID_CLIENT_ID=your_oneid_client_id
ONEDEX_ENABLED=false
REWARD_TOKEN_ADDRESS=your_token_address
ONERWA_ENABLED=false
NFT_COLLECTION_ADDRESS=your_nft_collection_address

# CORS
FRONTEND_URL=http://localhost:3000
